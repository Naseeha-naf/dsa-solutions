class Solution {
    public void moveZeroes(int[] nums) {
        int pos=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]!=0){
                nums[pos]=nums[i];
                pos++;
            }
            
        }
        for(int i=pos;i<nums.length;i++){ // if not put [1,3,12,3,12]
            nums[i]=0; //rem 0 fill
        }
    
        
    }
}
